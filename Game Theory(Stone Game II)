class Solution:
    def stoneGameII(self, piles: List[int]) -> int:
        memo,n={}, len(piles)

        for i in range(n-2,-1,-1):
            piles[i]+=piles[i+1]

        def dp(i,m):
            if i+2*m>=n:return piles[i]
            if(i,m)not in memo:
                memo[(i,m)]=piles[i]-min(dp(i+x,max(m,x))for x in range(1,2*m+1))
            return memo[(i,m)]
        return dp(0,1)
        

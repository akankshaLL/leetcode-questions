class Solution:
    def removeCoveredIntervals(self, intervals: List[List[int]]) -> int:
        intervals.sort(key=lambda x: (x[0],-x[1]))

        remaining=0
        curr_end=0

        for i in range(len(intervals)):
            if intervals[i][1]>curr_end:
                remaining+=1
                curr_end=intervals[i][1]

        return remaining     

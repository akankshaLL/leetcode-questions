import bisect
from typing import List

class Solution:
    def pathExistenceQueries(self, n: int, nums: List[int], maxDiff: int, queries: List[List[int]]) -> List[int]:
        # Step 1: Get sorted unique values from nums
        A = sorted(list(set(nums)))
        m = len(A)
        
        # Map each value to its index in the sorted unique array
        val_to_idx = {val: i for i, val in enumerate(A)}
        
        # Step 2: Compute the next maximum reachable index for each element
        # nxt_idx[i] is the furthest index we can jump to from A[i] in 1 step
        nxt_idx = [0] * m
        for i in range(m):
            target_val = A[i] + maxDiff
            # Find the largest element <= target_val
            pos = bisect.bisect_right(A, target_val) - 1
            nxt_idx[i] = pos
            
        # Step 3: Build the binary lifting table
        # up[i][j] stores the index reached from index i after 2^j steps
        LOG = 18  # 2^17 = 262144 > 10^5
        up = [[0] * LOG for _ in range(m)]
        
        for i in range(m):
            up[i][0] = nxt_idx[i]
            
        for j in range(1, LOG):
            for i in range(m):
                up[i][j] = up[up[i][j-1]][j-1]
                
        # Step 4: Process each query
        ans = []
        for u, v in queries:
            if u == v:
                ans.append(0)
                continue
                
            val_u, val_v = nums[u], nums[v]
            if val_u == val_v:
                ans.append(1)
                continue
                
            # Ensure we always move from smaller value to larger value
            if val_u > val_v:
                val_u, val_v = val_v, val_u
                
            idx_u = val_to_idx[val_u]
            idx_v = val_to_idx[val_v]
            
            steps = 0
            # Lift idx_u as far as possible without reaching or exceeding idx_v
            for j in range(LOG - 1, -1, -1):
                if up[idx_u][j] < idx_v:
                    idx_u = up[idx_u][j]
                    steps += (1 << j)
            
            # Take one final step to try and cover the remaining distance
            steps += 1
            idx_u = up[idx_u][0]
            
            if idx_u >= idx_v:
                ans.append(steps)
            else:
                ans.append(-1)
                
        return ans
